RUN_MODE=bot

TG_API_ID=1234567
TG_API_HASH=your_telegram_api_hash
TG_SESSION_NAME=tele_ai_userbot
BOT_TOKEN=1234567890:your_botfather_token

# Discord mode (run with: uv run discord-ai)
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_COMMAND_PREFIX=!
DISCORD_OWNER_ID=
DISCORD_ENABLE_GUILDS=true
DISCORD_ENABLE_DMS=true
DISCORD_STATE_DB_PATH=.discord_ai_state.db

NVIDIA_API_KEY=your_nvidia_api_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2-instruct-0905
NVIDIA_FALLBACK_MODEL=moonshotai/kimi-k2-instruct

# Optional dedicated Kimi fallback (if empty, fallback uses NVIDIA_FALLBACK_MODEL with NVIDIA key)
KIMI_API_KEY=
KIMI_BASE_URL=
KIMI_MODEL=

DEFAULT_TARGET_LANG=en
LANG_CONFIDENCE_THRESHOLD=0.70
MAX_TEXT_CHARS=4000
TRANSLATION_PREFIX=[AI-TR]
INCOMING_TRANSLATION_OUTPUT_MODE=saved_messages
ENABLE_GROUPS=true
ENABLE_PRIVATE=true
GLOBAL_PAUSE=false
LOG_LEVEL=INFO
STATE_DB_PATH=.tele_ai_state.db
SEND_INTERVAL_SECONDS=1.0
LANG_HISTORY_LIMIT=8
LANG_HISTORY_RETENTION_HOURS=24
STATE_CLEANUP_INTERVAL_MINUTES=60
PROCESSED_CACHE_TTL_SECONDS=600
PROCESSED_CACHE_MAXSIZE=20000
FAILURE_NOTICE_TTL_SECONDS=120
FAILURE_NOTICE_MAXSIZE=2000
